# Server
PORT=7860

# Encryption is handled by data/lumiverse.identity (auto-generated on first run).
# If migrating from an older version, set ENCRYPTION_KEY here and it will be
# migrated to the identity file automatically on next startup.
# ENCRYPTION_KEY=

# Optional: authentication secret (32-byte hex string)
# If omitted, automatically derived from data/lumiverse.identity.
# To set explicitly: openssl rand -hex 32
# AUTH_SECRET=

# Required: admin account password
OWNER_PASSWORD=

# Optional: admin account username (default: admin)
# OWNER_USERNAME=admin

# Optional: path to built frontend (e.g., ../LumiverseFrontend/dist)
# When set, the backend serves the frontend as static files.
# FRONTEND_DIR=

# Optional: comma-separated trusted origins for CORS
# Leave unset to allow all origins (development), or set for production:
# TRUSTED_ORIGINS=http://localhost:5173,http://localhost:7860

# Spindle ephemeral storage pools
# Global pool cap across all extensions (bytes)
SPINDLE_EPHEMERAL_GLOBAL_MAX_BYTES=524288000
# Default per-extension cap when no override is present (bytes)
SPINDLE_EPHEMERAL_EXTENSION_DEFAULT_MAX_BYTES=52428800
# Optional per-extension caps: identifier:maxBytes,identifier:maxBytes
# Example: simtracker:104857600,my_ext:20971520
SPINDLE_EPHEMERAL_EXTENSION_MAX_OVERRIDES=
# Reservation TTL for requested ephemeral blocks (milliseconds)
SPINDLE_EPHEMERAL_RESERVATION_TTL_MS=600000
